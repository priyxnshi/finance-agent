# Copy this file to .env and adjust as needed. All values below are also the defaults
# used if no .env file is present, so .env is optional for local development.

# SQLAlchemy database URL. SQLite file will be created relative to where uvicorn is run.
DATABASE_URL=sqlite:///./finvault.db

# Comma-separated list of origins allowed to call this API (your Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
